{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "allowImportingTsExtensions": false,
    "noEmit": false
  },
  "include": ["src/main/**/*.ts", "src/preload.ts", "src/lib/**/*.ts"]
}
