{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "esModuleInterop": true
  },
  "include": ["src/main/**/*.ts", "src/lib/**/*.ts"],
  "exclude": ["src/preload.ts"]
}
